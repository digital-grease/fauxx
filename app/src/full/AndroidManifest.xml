<?xml version="1.0" encoding="utf-8"?>
<!--
    Full (F-Droid / GitHub) flavor manifest overlay.

    Uses "specialUse" FGS type to match the play flavor — the runtime semantics
    are identical (continuous synthetic background traffic for privacy poisoning),
    and "specialUse" has no Android-enforced cumulative-runtime cap. "dataSync"
    was the original choice (closest plain-English match) but its 6h-per-24h cap
    on Android 14+ drove the FgsBudgetTracker machinery and a string of crashes
    (#64/#65). F-Droid does not enforce Google's FGS-type policy, so the same
    subtype rationale that satisfies Play also stands for F-Droid.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!--
        Mock-location permission for the Location Spoof module. Android's "Select
        mock location app" Developer Options selector lists apps that declare this
        permission. Without it, Fauxx never appears (issue #4). Lint flags this
        with MockLocation because it expects mock-location to be debug-only; we
        ship it in the full/F-Droid flavor deliberately and suppress the warning.

        The play flavor does NOT declare this — Play Store policy is stricter
        around mock location, and the play flavor's specialUse FGS subtype already
        carries reviewer scrutiny that mock location would compound.
    -->
    <uses-permission android:name="android.permission.ACCESS_MOCK_LOCATION"
        tools:ignore="MockLocation" />

    <application>
        <service
            android:name=".service.PhantomForegroundService"
            android:foregroundServiceType="specialUse"
            tools:node="merge">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Generates synthetic, off-profile browsing activity continuously in the background to dilute user-identifying signal available to third-party data brokers and ad-tech trackers. The service cannot be an instant-off/on worker because its privacy value depends on maintaining a stable, human-like traffic rhythm (Poisson-distributed cadence, 5-20 minute gaps, circadian quiet hours) that short-lived tasks cannot sustain." />
        </service>
    </application>

</manifest>
